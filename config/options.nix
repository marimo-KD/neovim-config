{
  globals = {
    mapleader = " ";
  };
  opts = {
    number = true;
    relativenumber = true;

    termguicolors = true;

    signcolumn = "yes";

    mouse = "a";

    ignorecase = true;
    smartcase = true;

    splitright = true;
    splitbelow = true;

    list = true;
    listchars.__raw = "{ tab = '» ', trail = '·', nbsp = '␣' }";

    expandtab = true;
    tabstop = 2;
    shiftwidth = 2;
    softtabstop = 0;
    smarttab = true;

    encoding = "utf-8";
    fileencoding = "utf-8";

    undofile = true;
    swapfile = true;
    backup = false;
    autoread = true;

    scrolloff = 5;
  };
}
